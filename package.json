{
  "name": "pearl-web-wallet",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "main": "electron/main.js",
  "description": "Non-custodial pure-web wallet for PRL + WPRL with native PearlBridge integration",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/sync-version.mjs && vite",
    "prebuild": "node scripts/sync-version.mjs",
    "build": "tsc --noEmit && vite build",
    "build:offline": "node scripts/sync-version.mjs && tsc --noEmit && vite build --config vite.config.offline.ts && node scripts/build-offline.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:start": "electron .",
    "electron:build": "npm run build && electron-builder --win --x64",
    "android:build": "npm run build && npx cap sync android"
  },
  "build": {
    "appId": "xyz.pearlwallet.desktop",
    "productName": "Pearl Wallet",
    "copyright": "MIT",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "shortcutName": "Pearl Wallet"
    }
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@noble/curves": "1.6.0",
    "@noble/hashes": "1.5.0",
    "@scure/base": "1.1.9",
    "@scure/bip32": "1.5.0",
    "@scure/bip39": "1.4.0",
    "@scure/btc-signer": "^1.4.0",
    "@tanstack/react-query": "^5.59.0",
    "dexie": "^4.0.8",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "viem": "2.21.19",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.7.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
