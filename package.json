{
  "name": "pearl-web-wallet",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "description": "Non-custodial pure-web wallet for PRL + WPRL with native PearlBridge integration",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/sync-version.mjs && vite",
    "prebuild": "node scripts/sync-version.mjs",
    "build": "tsc --noEmit && vite build",
    "build:offline": "node scripts/sync-version.mjs && tsc --noEmit && vite build --config vite.config.offline.ts && node scripts/build-offline.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/curves": "1.6.0",
    "@noble/hashes": "1.5.0",
    "@scure/base": "1.1.9",
    "@scure/bip32": "1.5.0",
    "@scure/bip39": "1.4.0",
    "@scure/btc-signer": "^1.4.0",
    "@tanstack/react-query": "^5.59.0",
    "dexie": "^4.0.8",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "viem": "2.21.19",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
